# Project Settings
PROJECT_NAME="Booky Voice Agent"

# Database Settings
# For PostgreSQL (Production), use:
# DATABASE_URL=postgresql+asyncpg://user:password@host:port/dbname
# For SQLite (Local), use:
# DATABASE_URL=sqlite+aiosqlite:///./test.db
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/booky

# Twilio Settings
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# OpenAI Settings
OPENAI_API_KEY=your_openai_api_key

# Security
# Shared secret for internal API authentication
API_SECRET_TOKEN=generate-a-secure-random-token-here

# CORS
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://your-frontend-domain.com
